<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="external" path="archive.csv"/>
        <include domain="external" path="database.csv"/>
        <include domain="external" path="day.csv"/>
        <include domain="external" path="currentrecipe.csv"/>
    </cloud-backup>
    <device-transfer>
        <include domain="external" path="archive.csv"/>
        <include domain="external" path="database.csv"/>
        <include domain="external" path="day.csv"/>
        <include domain="external" path="currentrecipe.csv"/>
    </device-transfer>
</data-extraction-rules>